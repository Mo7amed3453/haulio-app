{
  "version": 8,
  "name": "Haulio Dark",
  "metadata": {
    "maplibre:version": "1.0.0",
    "haulio:description": "Dark navigation style for delivery drivers"
  },
  "sources": {
    "haulio-tiles": {
      "type": "vector",
      "tiles": [
        "https://tiles.haulio.app/{z}/{x}/{y}.pbf"
      ],
      "maxzoom": 14,
      "attribution": "© OpenStreetMap contributors"
    }
  },
  "sprite": "",
  "glyphs": "https://tiles.haulio.app/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#1a1a2e"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "haulio-tiles",
      "source-layer": "water",
      "paint": {
        "fill-color": "#16213e",
        "fill-opacity": 1
      }
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "haulio-tiles",
      "source-layer": "landcover",
      "paint": {
        "fill-color": "#1e1e38",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "landuse-residential",
      "type": "fill",
      "source": "haulio-tiles",
      "source-layer": "landuse",
      "filter": ["==", "class", "residential"],
      "paint": {
        "fill-color": "#1f1f36"
      }
    },
    {
      "id": "landuse-commercial",
      "type": "fill",
      "source": "haulio-tiles",
      "source-layer": "landuse",
      "filter": ["==", "class", "commercial"],
      "paint": {
        "fill-color": "#22223a"
      }
    },
    {
      "id": "landuse-industrial",
      "type": "fill",
      "source": "haulio-tiles",
      "source-layer": "landuse",
      "filter": ["==", "class", "industrial"],
      "paint": {
        "fill-color": "#1c1c32"
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "haulio-tiles",
      "source-layer": "park",
      "paint": {
        "fill-color": "#1a2e1a",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "haulio-tiles",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#252540",
        "fill-opacity": 0.8
      }
    },
    {
      "id": "road-motorway",
      "type": "line",
      "source": "haulio-tiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "motorway"],
      "paint": {
        "line-color": "#4a4a6a",
        "line-width": {
          "stops": [[5, 1], [10, 3], [14, 6]]
        }
      },
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      }
    },
    {
      "id": "road-trunk",
      "type": "line",
      "source": "haulio-tiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "trunk"],
      "paint": {
        "line-color": "#3d3d5c",
        "line-width": {
          "stops": [[6, 0.5], [10, 2], [14, 4]]
        }
      },
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "haulio-tiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "primary"],
      "paint": {
        "line-color": "#353550",
        "line-width": {
          "stops": [[7, 0.5], [10, 1.5], [14, 3]]
        }
      },
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      }
    },
    {
      "id": "road-secondary",
      "type": "line",
      "source": "haulio-tiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "secondary"],
      "paint": {
        "line-color": "#2d2d44",
        "line-width": {
          "stops": [[8, 0.5], [12, 1], [14, 2]]
        }
      },
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "haulio-tiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "minor", "service"],
      "paint": {
        "line-color": "#262638",
        "line-width": {
          "stops": [[10, 0.5], [14, 1.5]]
        }
      },
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      }
    },
    {
      "id": "boundary-country",
      "type": "line",
      "source": "haulio-tiles",
      "source-layer": "boundary",
      "filter": ["==", "admin_level", 2],
      "paint": {
        "line-color": "#5a5a7a",
        "line-width": 1.5,
        "line-dasharray": [3, 2]
      }
    },
    {
      "id": "boundary-state",
      "type": "line",
      "source": "haulio-tiles",
      "source-layer": "boundary",
      "filter": ["==", "admin_level", 4],
      "minzoom": 4,
      "paint": {
        "line-color": "#3a3a55",
        "line-width": 1,
        "line-dasharray": [2, 2]
      }
    },
    {
      "id": "place-city",
      "type": "symbol",
      "source": "haulio-tiles",
      "source-layer": "place",
      "filter": ["==", "class", "city"],
      "layout": {
        "text-field": "{name}",
        "text-size": {
          "stops": [[4, 10], [8, 14], [12, 18]]
        },
        "text-font": ["Open Sans Regular"]
      },
      "paint": {
        "text-color": "#c0c0d8",
        "text-halo-color": "#1a1a2e",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-town",
      "type": "symbol",
      "source": "haulio-tiles",
      "source-layer": "place",
      "filter": ["==", "class", "town"],
      "minzoom": 7,
      "layout": {
        "text-field": "{name}",
        "text-size": {
          "stops": [[7, 9], [10, 12]]
        },
        "text-font": ["Open Sans Regular"]
      },
      "paint": {
        "text-color": "#a0a0b8",
        "text-halo-color": "#1a1a2e",
        "text-halo-width": 1
      }
    },
    {
      "id": "place-village",
      "type": "symbol",
      "source": "haulio-tiles",
      "source-layer": "place",
      "filter": ["==", "class", "village"],
      "minzoom": 10,
      "layout": {
        "text-field": "{name}",
        "text-size": 10,
        "text-font": ["Open Sans Regular"]
      },
      "paint": {
        "text-color": "#8080a0",
        "text-halo-color": "#1a1a2e",
        "text-halo-width": 1
      }
    },
    {
      "id": "road-label",
      "type": "symbol",
      "source": "haulio-tiles",
      "source-layer": "transportation_name",
      "minzoom": 12,
      "layout": {
        "text-field": "{name}",
        "text-size": 10,
        "text-font": ["Open Sans Regular"],
        "symbol-placement": "line"
      },
      "paint": {
        "text-color": "#7070a0",
        "text-halo-color": "#1a1a2e",
        "text-halo-width": 1
      }
    }
  ]
}
