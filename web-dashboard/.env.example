# Supabase project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Supabase anonymous/public key
VITE_SUPABASE_ANON_KEY=

# Tile server URL – defaults to OSM in dev
# Swap to Martin raster output once available (e.g. https://tiles.haulio.app/{z}/{x}/{y}.png)
VITE_TILES_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
